{
  "name": "@synapse-network/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Synapse Network API Gateway",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --testPathPattern='tests/unit' --runInBand --forceExit",
    "test:unit": "jest --testPathPattern='tests/unit' --runInBand --forceExit",
    "test:e2e": "jest --testPathPattern='tests/e2e/consumer' --runInBand --forceExit",
    "test:new-consumer": "jest --testPathPattern='tests/e2e/new-consumer' --runInBand --forceExit --verbose",
    "test:provider": "jest --testPathPattern='tests/e2e/provider' --runInBand --forceExit --verbose",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "ethers": ">=5.0.0 <7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.7",
    "ethers": "^6.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.2"
  }
}
